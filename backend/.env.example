# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=homework_system

# JWT
JWT_SECRET_KEY=your-jwt-secret-key
JWT_EXPIRE_HOURS=24

# Qwen API (可选，不配置则 AI 功能不可用)
QWEN_API_KEY=
QWEN_MODEL=qwen-turbo
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Flask
FLASK_DEBUG=true
FLASK_PORT=5000

# 文件上传
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
